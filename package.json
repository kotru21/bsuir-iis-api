{
  "name": "bsuir-iis-api",
  "version": "0.2.6",
  "description": "Type-safe ESM SDK for BSUIR IIS API",
  "type": "module",
  "author": "kotru21",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kotru21/bsuir-iis-api.git"
  },
  "homepage": "https://github.com/kotru21/bsuir-iis-api#readme",
  "bugs": {
    "url": "https://github.com/kotru21/bsuir-iis-api/issues"
  },
  "keywords": [
    "bsuir",
    "iis",
    "schedule",
    "api",
    "sdk",
    "typescript"
  ],
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:live": "vitest run test/integration/live-api.contract.test.ts",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run typecheck && npm run test",
    "check:full": "npm run lint && npm run typecheck && npm run test:coverage",
    "prepublishOnly": "npm run build",
    "release:dry": "npm pack --dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
